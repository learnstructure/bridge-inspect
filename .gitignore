# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv
env/
venv/
ENV/

# --- Conda ---
.conda/
conda-meta/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- UI & Resources ---
# If you use Qt Designer to create .ui files, you'll generate .py files from them
# Keep the .ui, but you can ignore the auto-generated python UI code if you prefer
# ui/*_rc.py
# ui/*_ui.py

# --- Computer Vision & ML (IMPORTANT) ---
# Do not upload heavy model weights (e.g., .pt, .pth, .onnx)
# It is better to download these from a cloud link or keep them local
models/*.pt
models/*.pth
models/*.onnx
models/*.weights
datasets/
data/raw/
data/processed/

# --- Databases ---
# Ignore local SQLite databases containing bridge data
*.sqlite
*.db

# --- Structural Analysis (OpenSees) ---
# Ignore output files generated by OpenSees solvers
*.out
*.txt
# If you generate specific analysis logs
analysis_results/

# --- Operating System ---
.DS_Store
Thumbs.db

# --- Distribution ---
dist/
build/
*.spec